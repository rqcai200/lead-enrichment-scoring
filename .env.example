# Copy to .env and fill in. In GitHub Actions, set these as repo Secrets instead.
# .env is gitignored — never commit real tokens.

# Your CRM (example: Attio). Read leads + write back enriched fields & score.
CRM_API_TOKEN=your_crm_token_here

# Apify — the enrichment engine (runs the LinkedIn profile + posts scrapers).
APIFY_TOKEN=your_apify_token_here

# Optional: email -> LinkedIn profile fallback for email-only leads
# (e.g. Reverse Contact). Leave unset to skip the email path.
REVERSE_CONTACT_API_KEY=

# Optional: a cheap LLM for the wrong-person guard's arbiter
# (e.g. Gemini Flash). Without it, name mismatches are flagged, not auto-rejected.
LLM_API_KEY=
